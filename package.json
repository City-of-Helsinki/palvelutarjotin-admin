{
  "name": "palvelutarjotin-admin",
  "version": "1.19.5",
  "license": "MIT",
  "contributors": [
    "Jori Lindell"
  ],
  "private": true,
  "type": "module",
  "engines": {
    "node": "^24"
  },
  "packageManager": "yarn@1.22.22",
  "//": {
    "Why are packages in resolutions?": {
      "@types/react": [
        "Several packages may still resolve different @types/react versions",
        "Pinning @types/react to v19 keeps typechecking consistent with React v19",
        "NOTE: This can be removed when transitive dependencies are aligned on @types/react v19"
      ],
      "draft-js/immutable and @types/draft-js/immutable": [
        "To force a patched immutable version for transitive dependencies in draft-js stack still requesting immutable 3.x",
        "See https://www.npmjs.com/advisories/1114158",
        "NOTE: This can be removed when draft-js stack no longer depends on vulnerable immutable 3.7.x"
      ],
      "**/@ardatan/relay-compiler/immutable": [
        "To force a patched immutable 3.x version for graphql-codegen relay compiler chain",
        "See https://www.npmjs.com/advisories/1114158",
        "NOTE: This can be removed when @ardatan/relay-compiler no longer depends on immutable 3.7.x"
      ],
      "hds-react/cookie": [
        "To fix https://github.com/City-of-Helsinki/palvelutarjotin-admin/security/dependabot/125",
        "NOTE: This can be removed if hds-react starts to depend on >=v1 cookie"
      ],
      "lodash": [
        "To fix GHSA-f23m-r3pf-42rh and GHSA-r5fr-rjxr-66jc",
        "Pinning lodash to >=4.18.1 fixes prototype pollution vulnerabilities",
        "NOTE: This can be removed when all transitive dependencies use patched lodash versions"
      ],
      "tmp": [
        "tmp allows arbitrary temporary file/directory write via symbolic link in versions <0.2.4",
        "Pinning to >=0.2.4 via @graphql-codegen/cli > inquirer > external-editor > tmp",
        "See https://www.npmjs.com/advisories/1109537",
        "NOTE: This can be removed when @graphql-codegen/cli no longer resolves vulnerable tmp versions"
      ]
    }
  },
  "resolutions": {
    "draft-js/immutable": "3.8.3",
    "**/@ardatan/relay-compiler/immutable": "3.8.3",
    "@types/draft-js/immutable": "3.8.3",
    "@types/react": "^19.2.14",
    "hds-react/cookie": "^0.7.2",
    "lodash": "^4.18.1",
    "tmp": ">=0.2.4",
    "hds-core": "file:.yalc/hds-core",
    "hds-design-tokens": "file:.yalc/hds-design-tokens"
  },
